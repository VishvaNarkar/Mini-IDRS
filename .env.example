# ============================================================
# Mini IDRS — Secrets Template
# ============================================================
# Copy this file to .env and fill in REAL values.
# IMPORTANT: .env is gitignored — never commit it.
# Non-secret config (IPs, thresholds, paths) goes in config.yaml.
# ============================================================

# ---- Firewall REST API (runs on Linux Firewall VM) ----
# Used by: FirewallManager (Monitor) to authenticate to Firewall API
FIREWALL_API_KEY=replace-with-a-strong-random-key

# ---- IDS REST API (runs on Monitor VM) ----
# Used by: Dashboard and any external client
IDS_API_KEY=replace-with-a-strong-random-key

# ---- Victim VM SSH credentials ----
# Used by: VictimBlocker to add/remove iptables INPUT rules
# Recommendation: use SSH key auth and remove VICTIM_SSH_PASS from here
VICTIM_SSH_USER=victim
VICTIM_SSH_PASS=changeme
